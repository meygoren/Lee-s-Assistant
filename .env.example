# Local dev secrets — copy to .env.local and fill in

# Single shared password for logging in (this is a private single-user app)
LEE_APP_PASSWORD=change-me

# Random long string used to sign the login session cookie
SESSION_SECRET=change-me-to-a-long-random-string

# You need ONE of these two for the assistant + AI newsletter + crypto news
# to actually work. Leave both blank to see the app with placeholder content.

# Anthropic API key (paid, pay-as-you-go) — get one at console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: override the Claude model used for the assistant + newsletter
# ANTHROPIC_MODEL=claude-sonnet-5

# Gemini API key (free, no credit card needed) — get one at aistudio.google.com.
# Used automatically when ANTHROPIC_API_KEY is not set.
GEMINI_API_KEY=

# Optional: override the Gemini model used for the assistant + newsletter
# GEMINI_MODEL=gemini-3.5-flash

# Note: the WeChat Work (企业微信) bot webhook URL, and the Telegram chat ID,
# are both configured from the Settings tab inside the app (stored in the
# database), not as env vars.

# Telegram bot token — get one for free from @BotFather on Telegram.
# Leave blank to skip Telegram notifications.
TELEGRAM_BOT_TOKEN=

# Secret used to protect /api/cron/newsletter from being triggered by
# anyone but your scheduler (Vercel Cron sends this as a Bearer token
# automatically when CRON_SECRET is set in your Vercel project).
CRON_SECRET=

# A Postgres connection string. On Vercel, add Postgres storage from the
# project's Storage tab and this gets set for you automatically. For local
# dev, use that same connection string, or any other Postgres database.
DATABASE_URL=
